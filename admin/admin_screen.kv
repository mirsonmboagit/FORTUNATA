<AdminHoverCard@HoverCard>:
    hover_bg_mix: 0.05
    hover_line_mix: 0.24
    hover_elevation_delta: 1.2
    hover_accent_color: app.theme_tokens["primary"]

<AdminActionButton@HoverTooltipRaisedButton>:
    press_enabled: True
    hover_bg_mix: 0.12
    hover_line_mix: 0.22
    hover_elevation_delta: 2
    press_bg_mix: 0.18
    press_line_mix: 0.34
    press_elevation_delta: 0.8
    hover_accent_color: [1, 1, 1, 1]

<AdminScreen>:
    product_table: product_table
    search_input: search_input
    category_spinner: category_spinner

    FloatLayout:
        MDBoxLayout:
            orientation: 'vertical'
            md_bg_color: app.theme_tokens['surface']
            padding: 0
            spacing: 0

            # HEADER - Navegação Principal
            MDTopAppBar:
                id: header_bar
                title: "Gestao de produtos"
                md_bg_color: app.theme_tokens['primary']
                specific_text_color: app.theme_tokens['on_primary']
                elevation: 4
                size_hint_y: None
                height: max(dp(56), root.height * 0.07)
                left_action_items: [["view-dashboard-outline", lambda x: root.go_home(), "Pagina inicial (Alt+1)"]]
                right_action_items: [["package-variant-plus", lambda x: root.open_restock_screen(), "Reposicao (Alt+2)"], ["alert-circle", lambda x: root.open_losses_screen(), "Perdas (Alt+3)"], ["chart-bar", lambda x: root.generate_report(), "Relatorios (Alt+4)"], ["cog", lambda x: root.go_to_definitions(), "Definicoes (Alt+S)"], ["logout", lambda x: root.logout(), "Terminar sessao"]]

            # BARRA DE FERRAMENTAS COMPACTA
            AdminHoverCard:
                id: toolbar_card
                size_hint_y: None
                height: max(dp(70), root.height * 0.08)
                padding: [dp(18), dp(10)]
                spacing: dp(10)
                elevation: 2
                md_bg_color: app.theme_tokens['card']
                radius: [0, 0, 0, 0]

                MDBoxLayout:
                    id: toolbar_row
                    spacing: dp(10)

                    TooltipTextField:
                        id: search_input
                        hint_text: "Pesquisar produto..."
                        tooltip_text: "Pesquisar produto (/ ou Ctrl+F)"
                        mode: "rectangle"
                        size_hint_x: 0.29
                        icon_left: "magnify"
                        on_text: root.queue_filter(self.text)
                        font_size: sp(14)

                    # Filtro de Categorias
                    AdminActionButton:
                        id: category_spinner
                        text: "Todas as Categorias"
                        tooltip_text: "Abrir categorias (Alt+C)"
                        size_hint_x: 0.18
                        md_bg_color: app.theme_tokens['card_alt']
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_primary']
                        hover_accent_color: app.theme_tokens['primary']
                        elevation: 1
                        on_release: root.show_category_menu(self)
                        font_size: sp(13)

                    AdminActionButton:
                        id: filter_btn
                        text: "Filtrar"
                        icon: "filter-variant"
                        tooltip_text: "Alternar filtro KG/unidade/todos (Alt+F)"
                        md_bg_color: app.theme_tokens['warning']
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['on_primary']
                        hover_accent_color: [1, 1, 1, 1]
                        size_hint_x: None
                        width: dp(48)
                        on_release: root.toggle_kg_products()
                        font_size: sp(13)

                    AdminActionButton:
                        id: add_btn
                        text: "Adicionar"
                        icon: "plus-circle"
                        tooltip_text: "Adicionar produto (Ctrl+N)"
                        md_bg_color: app.theme_tokens['success']
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['on_primary']
                        hover_accent_color: [1, 1, 1, 1]
                        size_hint_x: 0.13
                        on_release: root.add_product()
                        font_size: sp(13)

                    AdminActionButton:
                        id: shopping_list_btn
                        text: "Lista de Compras"
                        icon: "cart-outline"
                        tooltip_text: "Ver lista de compras"
                        md_bg_color: app.theme_tokens['info']
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['on_primary']
                        hover_accent_color: [1, 1, 1, 1]
                        size_hint_x: 0.18
                        disabled: root.shopping_list_busy
                        on_release: root.open_shopping_list_preview()
                        font_size: sp(13)

                    

            # TABELA DE PRODUTOS MELHORADA
            MDBoxLayout:
                size_hint_y: 1
                padding: [dp(12), dp(8), dp(12), dp(12)]

                AdminHoverCard:
                    orientation: 'vertical'
                    spacing: 0
                    elevation: 3
                    md_bg_color: app.theme_tokens['card']
                    radius: [dp(6), dp(6), dp(6), dp(6)]

                    ScrollView:
                        id: table_scroll_x
                        size_hint_y: 1
                        do_scroll_x: True
                        do_scroll_y: False
                        bar_width: dp(6)
                        bar_color: 0.18, 0.28, 0.48, 0.7
                        bar_inactive_color: 0.18, 0.28, 0.48, 0.3
                        effect_cls: "ScrollEffect"

                        MDBoxLayout:
                            id: table_scroll_content
                            orientation: "vertical"
                            size_hint_x: None
                            width: max(root.width, dp(980))
                            size_hint_y: 1

                            MDBoxLayout:
                                id: table_header
                                size_hint_y: None
                                height: max(dp(44), root.height * 0.052)
                                size_hint_x: None
                                width: table_scroll_content.width
                                md_bg_color: app.theme_tokens['surface_alt']
                                padding: [dp(8), 0]
                                canvas.after:
                                    Color:
                                        rgba: app.theme_tokens['divider']
                                    Line:
                                        width: 1
                                        rectangle: self.x, self.y, self.width, self.height

                                MDLabel:
                                    text: "SEQ."
                                    bold: True
                                    size_hint_x: 0.06
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "PRODUTO"
                                    bold: True
                                    size_hint_x: 0.20
                                    halign: "left"
                                    padding: [dp(10), 0]
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "ESTOQUE"
                                    bold: True
                                    size_hint_x: 0.09
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "VENDIDO"
                                    bold: True
                                    size_hint_x: 0.09
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "TIPO"
                                    bold: True
                                    size_hint_x: 0.07
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "PRECO"
                                    bold: True
                                    size_hint_x: 0.11
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "LUCRO"
                                    bold: True
                                    size_hint_x: 0.11
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "DATA DE VALIDADE"
                                    bold: True
                                    size_hint_x: 0.13
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                                MDLabel:
                                    text: "ACOES"
                                    bold: True
                                    size_hint_x: 0.14
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    font_style: "Subtitle2"

                            MDSeparator:
                                height: dp(1)
                                color: app.theme_tokens['divider']

                            ScrollView:
                                size_hint_y: 1
                                do_scroll_x: False
                                do_scroll_y: True
                                bar_width: dp(8)
                                bar_color: 0.18, 0.28, 0.48, 0.7
                                bar_inactive_color: 0.18, 0.28, 0.48, 0.3
                                effect_cls: "ScrollEffect"

                                MDGridLayout:
                                    id: product_table
                                    cols: 9
                                    size_hint_y: None
                                    height: self.minimum_height
                                    size_hint_x: None
                                    width: table_scroll_content.width
                                    row_default_height: max(dp(46), root.height * 0.054)
                                    spacing: 0
                                    padding: 0
        
        FloatLayout:
            id: ai_banner_container
            size_hint: 1, 1
            pos: 0, 0
        
        DraggableTooltipFloatingActionButton:
            id: ai_button
            icon: "assets/icon/idea.ico"
            elevation: 2
            pos_hint: {"right": 0.965, "y": 0.04}
            hint_text: "Assistente IA"
            on_release: root.open_ai_menu(self)

        # Badge com número de notificações (só aparece quando > 0)
        MDCard:
            id: ai_badge
            size_hint: None, None
            size: dp(24), dp(24)
            md_bg_color: app.theme_tokens['badge']
            radius: [dp(12)]
            elevation: 1
            pos: ai_button.right - (self.width * 0.55), ai_button.top - (self.height * 0.45)
            opacity: 0

            MDLabel:
                id: ai_badge_label
                text: "0"
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: app.theme_tokens['on_primary']
                font_size: dp(12)
                bold: True

        # Ações rápidas ao lado da lâmpada (toggle + scroll)
        HoverTooltipIconButton:
            id: ai_toggle_button
            icon: "chevron-left" if root.quick_actions_open else "chevron-right"
            size_hint: None, None
            size: dp(38), dp(38)
            pos: max(dp(8), ai_button.x - self.width - dp(10)), ai_button.y
            on_release: root.toggle_quick_actions()
            md_bg_color: app.theme_tokens['primary']
            theme_text_color: "Custom"
            text_color: [1, 1, 1, 1]
            hint_text: "Mostrar/Ocultar Ações"

        ScrollView:
            id: ai_quick_actions_scroll
            size_hint: None, None
            width: min(root.width * 0.35, dp(220)) if root.quick_actions_open else 0
            height: dp(48) if root.quick_actions_open else 0
            opacity: 1 if root.quick_actions_open else 0
            disabled: not root.quick_actions_open
            pos: max(dp(8), ai_toggle_button.x - self.width - dp(10)), max(dp(8), ai_button.y - dp(2))
            do_scroll_x: True
            do_scroll_y: False
            bar_width: dp(4)
            bar_color: 0.18, 0.28, 0.48, 0.6
            bar_inactive_color: 0.18, 0.28, 0.48, 0.2
            effect_cls: "ScrollEffect"

            MDBoxLayout:
                orientation: "horizontal"
                size_hint_x: None
                width: self.minimum_width
                height: self.minimum_height
                padding: [dp(4), 0, dp(4), 0]
                spacing: dp(8)

                HoverTooltipIconButton:
                    icon: "alert-circle"
                    on_release: root.show_fraud_alerts()
                    md_bg_color: app.theme_tokens['danger']
                    theme_text_color: "Custom"
                    text_color: [1, 1, 1, 1]
                    hint_text: "Alertas de Fraude"

                HoverTooltipIconButton:
                    icon: "chart-line"
                    on_release: root.show_loss_metrics()
                    md_bg_color: app.theme_tokens['info']
                    theme_text_color: "Custom"
                    text_color: [1, 1, 1, 1]
                    hint_text: "Métricas de Perdas"

                HoverTooltipIconButton:
                    icon: "check-circle"
                    on_release: root.show_pending_approvals()
                    md_bg_color: app.theme_tokens['warning']
                    theme_text_color: "Custom"
                    text_color: [1, 1, 1, 1]
                    hint_text: "Aprovações Pendentes"
