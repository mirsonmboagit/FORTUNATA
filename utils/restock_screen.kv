<RestockScreen>:
    name: "restock"
    md_bg_color: app.theme_tokens['surface']

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Reposicao de Stock"
            md_bg_color: app.theme_tokens['primary']
            specific_text_color: app.theme_tokens['on_primary']
            elevation: 4
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            right_action_items: [["refresh", lambda x: root.force_refresh()], ["history", lambda x: root.open_restock_history()]]

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(16)
                spacing: dp(12)

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(8)

                    MDRaisedButton:
                        id: mode_in_btn
                        text: "ENTRADA"
                        size_hint_x: 0.23
                        font_size: dp(12)
                        on_release: root.set_mode("IN")

                    MDRaisedButton:
                        id: mode_out_btn
                        text: "SAIDA"
                        size_hint_x: 0.28
                        font_size: dp(12)
                        on_release: root.set_mode("OUT")

                    MDRaisedButton:
                        text: "MOVIMENTOS"
                        size_hint_x: 0.44
                        font_size: dp(12)
                        md_bg_color: app.theme_tokens['surface_alt']
                        text_color: app.theme_tokens['text_primary']
                        on_release: root.open_recent_movements_modal()

                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(360)
                    padding: [dp(12), dp(10)]
                    spacing: dp(8)
                    radius: [dp(10)]
                    elevation: 2
                    md_bg_color: app.theme_tokens['card']

                    MDLabel:
                        text: "Produtos"
                        font_style: "Subtitle1"
                        bold: True
                        size_hint_y: None
                        height: dp(26)

                    MDTextField:
                        id: search_input
                        hint_text: "Nome, ID ou Codigo de Barras"
                        mode: "rectangle"
                        size_hint_y: None
                        height: dp(44)
                        on_text: root.on_search(self.text)
                        on_text_validate: root.on_search_enter()

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        md_bg_color: app.theme_tokens['primary']
                        padding: [dp(6), 0]
                        spacing: dp(4)

                        MDLabel:
                            text: "ID"
                            size_hint_x: 0.08
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "PRODUTO"
                            size_hint_x: 0.24
                            halign: "left"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "STOCK"
                            size_hint_x: 0.11
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "V/DIA"
                            size_hint_x: 0.09
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "DIAS"
                            size_hint_x: 0.09
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "VENC."
                            size_hint_x: 0.13
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "ULT. ATUAL"
                            size_hint_x: 0.14
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                        MDLabel:
                            text: "ACAO"
                            size_hint_x: 0.12
                            halign: "center"
                            bold: True
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']

                    ScrollView:
                        do_scroll_x: False
                        size_hint_y: 1

                        MDGridLayout:
                            id: products_table
                            cols: 1
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)

                MDCard:
                    id: stock_form_hidden_card
                    orientation: "vertical"
                    size_hint_y: None
                    height: 0
                    opacity: 0
                    disabled: True
                    padding: [0, 0]
                    spacing: 0
                    radius: [dp(10)]
                    elevation: 2
                    md_bg_color: app.theme_tokens['card']

                    MDLabel:
                        id: form_title
                        text: "Registo de Entrada"
                        font_style: "Subtitle1"
                        bold: True
                        size_hint_y: None
                        height: dp(26)

                    MDLabel:
                        id: selected_product_label
                        text: "Produto: --"
                        size_hint_y: None
                        height: dp(22)
                        theme_text_color: "Primary"

                    MDLabel:
                        id: selected_stock_label
                        text: "Stock atual: --"
                        size_hint_y: None
                        height: dp(22)
                        theme_text_color: "Secondary"

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(52)
                        spacing: dp(8)

                        MDTextField:
                            id: qty_input
                            hint_text: "Quantidade *"
                            mode: "rectangle"
                            input_filter: "float"
                            multiline: False
                            on_text_validate: root._advance_restock_form()
                            text: "1"

                        MDTextField:
                            id: note_input
                            hint_text: "Observacao"
                            mode: "rectangle"
                            multiline: False
                            on_text_validate: root.register_movement()

                    MDBoxLayout:
                        id: entry_expiry_row
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(52)
                        spacing: dp(8)

                        MDTextField:
                            id: expiry_input
                            hint_text: "Validade do lote DD/MM/AAAA"
                            mode: "rectangle"
                            multiline: False
                            on_text_validate: root._advance_restock_form()

                    MDBoxLayout:
                        id: entry_cost_row
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(52)
                        spacing: dp(8)

                        MDTextField:
                            id: unit_cost_input
                            hint_text: "Custo unitario *"
                            mode: "rectangle"
                            input_filter: "float"
                            multiline: False
                            on_text_validate: root._focus_field("note_input", select_all=True)

                    MDBoxLayout:
                        id: entry_supplier_row
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(52)
                        spacing: dp(8)

                        MDTextField:
                            id: supplier_input
                            hint_text: "Fornecedor (opcional)"
                            mode: "rectangle"

                        MDTextField:
                            id: invoice_input
                            hint_text: "N. Fatura (opcional)"
                            mode: "rectangle"

                    MDBoxLayout:
                        id: out_type_row
                        orientation: "horizontal"
                        size_hint_y: None
                        height: 0
                        opacity: 0
                        disabled: True
                        spacing: dp(8)

                        MDTextField:
                            id: movement_type_field
                            hint_text: "Tipo de saida"
                            mode: "rectangle"
                            readonly: True
                            text: "AJUSTE"

                        MDFlatButton:
                            id: movement_type_btn
                            text: "TIPO"
                            size_hint_x: None
                            width: dp(90)
                            on_release: root.open_movement_type_menu()

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(52)
                        spacing: dp(8)

                        MDTextField:
                            id: entry_date_field
                            hint_text: "Data de Entrada"
                            mode: "rectangle"
                            readonly: True
                            text: "--"

                        MDTextField:
                            id: exit_date_field
                            hint_text: "Data de Saida"
                            mode: "rectangle"
                            readonly: True
                            text: "--"

                        MDTextField:
                            id: update_day_field
                            hint_text: "Dia de Atualizacao"
                            mode: "rectangle"
                            readonly: True
                            text: "--"

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(44)
                        spacing: dp(8)

                        MDFlatButton:
                            text: "LIMPAR"
                            on_release: root.clear_form()

                        MDRaisedButton:
                            id: submit_btn
                            text: "REGISTAR ENTRADA"
                            on_release: root.register_movement()
