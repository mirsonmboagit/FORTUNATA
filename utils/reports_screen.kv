<ReportsPanelCard@HoverCard>:
    elevation: 1
    radius: [dp(12)]
    line_color: app.theme_tokens['divider']
    line_width: 1
    hover_bg_mix: 0.06
    hover_line_mix: 0.24
    hover_elevation_delta: 1.6
    hover_duration: 0.14
    hover_accent_color: app.theme_tokens['primary']

<ReportsGhostButton@HoverRaisedButton>:
    elevation: 0
    radius: [dp(12)]
    line_color: app.theme_tokens['divider']
    line_width: 1
    press_enabled: True
    hover_bg_mix: 0.14
    hover_line_mix: 0.22
    hover_elevation_delta: 1.6
    hover_duration: 0.12

<ReportsAccentButton@HoverRaisedButton>:
    radius: [dp(12)]
    line_width: 1
    press_enabled: True
    hover_bg_mix: 0.10
    hover_line_mix: 0.20
    hover_elevation_delta: 2.4
    hover_duration: 0.12

<ReportsRangeButton@HoverRaisedButton>:
    size_hint_y: None
    height: dp(42)
    elevation: 0
    radius: [dp(12)]
    line_color: app.theme_tokens['divider']
    line_width: 1
    press_enabled: True
    hover_bg_mix: 0.14
    hover_line_mix: 0.22
    hover_elevation_delta: 1.6
    hover_duration: 0.12

<ReportsReportButton@HoverRaisedButton>:
    size_hint_y: None
    height: dp(104)
    radius: [dp(18)]
    font_size: sp(15)
    elevation: 3
    press_enabled: True
    hover_bg_mix: 0.12
    hover_line_mix: 0.24
    hover_elevation_delta: 2.8
    hover_duration: 0.12
    line_width: 1.2

<ReportsScreen>:
    name: 'reports'
    date_label: date_label
    product_spinner: product_spinner
    category_spinner: category_spinner
    seller_spinner: seller_spinner

    FloatLayout:
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 0
            md_bg_color: app.theme_tokens['surface']

            # ── Header ──────────────────────────────────────────────
            MDCard:
                id: header_card
                size_hint_y: None
                height: dp(74)
                padding: [dp(25), dp(12), dp(25), dp(12)]
                elevation: 2
                md_bg_color: app.theme_tokens['card']
                radius: [0, 0, 0, 0]

                MDBoxLayout:
                    id: header_content
                    orientation: 'horizontal'
                    spacing: dp(20)

                    MDBoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.7
                        spacing: dp(2)
                        adaptive_height: True

                        MDLabel:
                            text: 'Relatorios'
                            font_style: 'H5'
                            bold: True
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']
                            size_hint_y: None
                            height: dp(30)

                        MDLabel:
                            text: 'Analise e exportacao de dados'
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_y: None
                            height: dp(20)

                    MDBoxLayout:
                        id: header_actions
                        orientation: 'horizontal'
                        size_hint_x: 0.3
                        spacing: dp(10)
                        adaptive_height: True

                        ReportsGhostButton:
                            id: hero_pdf_button
                            text: 'Todos PDFs'
                            size_hint_x: 0.36
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['primary']
                            hover_accent_color: app.theme_tokens['primary']
                            line_color: 0.15, 0.52, 0.76, 1
                            line_width: 1.5
                            on_release: root.show_pdf_viewer()

                        ReportsGhostButton:
                            id: hero_refresh_button
                            text: 'Atualizar'
                            size_hint_x: 0.32
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['info']
                            hover_accent_color: app.theme_tokens['info']
                            line_color: 0.28, 0.47, 0.84, 1
                            line_width: 1.5
                            on_release: root.refresh_screen_data()

                        ReportsGhostButton:
                            id: hero_back_button
                            text: 'Voltar'
                            size_hint_x: 0.26
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['danger']
                            hover_accent_color: app.theme_tokens['danger']
                            line_color: 0.85, 0.3, 0.3, 1
                            line_width: 1.5
                            on_release: root.go_back()

            # ── Body ─────────────────────────────────────────────────
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True
                bar_width: dp(4)

                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(16)
                    padding: [dp(20), dp(16), dp(20), dp(20)]
                    size_hint_y: None
                    height: self.minimum_height

                    # ── Filtros ──────────────────────────────────────
                    ReportsPanelCard:
                        id: filters_card
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(0)
                        padding: [dp(20), dp(16), dp(20), dp(16)]
                        md_bg_color: app.theme_tokens['card']
                        radius: [dp(14)]
                        hover_accent_color: app.theme_tokens['info']

                        MDLabel:
                            text: 'Configurar Filtros'
                            font_style: 'H6'
                            bold: True
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']
                            size_hint_y: None
                            height: dp(30)

                        Widget:
                            size_hint_y: None
                            height: dp(8)

                        # Pesquisa
                        MDBoxLayout:
                            id: search_row
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(48)
                            spacing: dp(10)

                            MDTextField:
                                id: report_search_input
                                hint_text: 'Pesquisar relatorio, produto ou categoria'
                                mode: 'rectangle'
                                icon_left: 'magnify'
                                on_text: root.on_search(self.text)
                                on_text_validate: root.on_search_enter()

                            ReportsGhostButton:
                                id: search_clear_button
                                text: 'Limpar'
                                size_hint_x: None
                                width: dp(110)
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['text_primary']
                                hover_accent_color: app.theme_tokens['primary']
                                on_release: root.clear_search()

                        MDLabel:
                            text: root.search_status_text
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]

                        Widget:
                            size_hint_y: None
                            height: dp(10)

                        # Período
                        MDBoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(48)
                            spacing: dp(12)

                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(2)

                                MDLabel:
                                    text: 'Periodo do Relatorio'
                                    font_style: 'Caption'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(18)

                                MDLabel:
                                    id: date_label
                                    text: 'Nenhum periodo selecionado'
                                    font_style: 'Body2'
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(22)

                            ReportsAccentButton:
                                text: 'Selecionar Periodo'
                                size_hint_x: None
                                width: dp(180)
                                md_bg_color: app.theme_tokens['warning']
                                text_color: app.theme_tokens['on_primary']
                                hover_accent_color: [1, 1, 1, 1]
                                line_color: 1, 1, 1, 0.12
                                on_release: root.select_date_range()

                        Widget:
                            size_hint_y: None
                            height: dp(8)

                        # Atalhos de período
                        MDGridLayout:
                            id: quick_range_grid
                            cols: 4
                            spacing: dp(8)
                            size_hint_y: None
                            height: dp(42)

                            ReportsRangeButton:
                                text: 'Hoje'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['warning']
                                hover_accent_color: app.theme_tokens['warning']
                                on_release: root.apply_today_range()

                            ReportsRangeButton:
                                text: '7 Dias'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['primary']
                                hover_accent_color: app.theme_tokens['primary']
                                on_release: root.apply_last_days_range(7)

                            ReportsRangeButton:
                                text: '30 Dias'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['success']
                                hover_accent_color: app.theme_tokens['success']
                                on_release: root.apply_last_days_range(30)

                            ReportsRangeButton:
                                text: 'Este Mes'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['info']
                                hover_accent_color: app.theme_tokens['info']
                                on_release: root.apply_current_month_range()

                        Widget:
                            size_hint_y: None
                            height: dp(10)

                        # Produto / Categoria
                        MDGridLayout:
                            id: filters_grid
                            cols: 2
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(64)

                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(2)

                                MDLabel:
                                    text: 'Produto'
                                    font_style: 'Caption'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(18)

                                ReportsGhostButton:
                                    id: product_spinner
                                    text: 'Todos os Produtos'
                                    md_bg_color: app.theme_tokens['card_alt']
                                    text_color: app.theme_tokens['text_primary']
                                    hover_accent_color: app.theme_tokens['primary']
                                    on_release: root.open_product_menu(self)

                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(2)

                                MDLabel:
                                    text: 'Categoria'
                                    font_style: 'Caption'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(18)

                                ReportsGhostButton:
                                    id: category_spinner
                                    text: 'Todas as Categorias'
                                    md_bg_color: app.theme_tokens['card_alt']
                                    text_color: app.theme_tokens['text_primary']
                                    hover_accent_color: app.theme_tokens['info']
                                    on_release: root.open_category_menu(self)

                        Widget:
                            size_hint_y: None
                            height: dp(8)

                        # Vendedor / Gerente
                        MDBoxLayout:
                            id: seller_filter_row
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(48)
                            spacing: dp(12)

                            MDBoxLayout:
                                orientation: 'vertical'
                                spacing: dp(2)

                                MDLabel:
                                    text: 'Vendedor/Gerente'
                                    font_style: 'Caption'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(18)

                                ReportsGhostButton:
                                    id: seller_spinner
                                    text: 'Todos os Vendedores'
                                    md_bg_color: app.theme_tokens['card_alt']
                                    text_color: app.theme_tokens['text_primary']
                                    hover_accent_color: app.theme_tokens['warning']
                                    on_release: root.open_seller_menu(self)

                        Widget:
                            size_hint_y: None
                            height: dp(10)

                        # Acções de filtro
                        MDBoxLayout:
                            id: filter_actions
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(40)
                            spacing: dp(10)

                            ReportsGhostButton:
                                id: filter_reset_button
                                text: 'Limpar Filtros'
                                size_hint_x: 0.5
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['text_primary']
                                hover_accent_color: app.theme_tokens['warning']
                                on_release: root.reset_filters()

                            ReportsAccentButton:
                                id: filter_refresh_button
                                text: 'Atualizar Dados'
                                size_hint_x: 0.5
                                md_bg_color: app.theme_tokens['info']
                                text_color: app.theme_tokens['on_primary']
                                hover_accent_color: [1, 1, 1, 1]
                                line_color: 1, 1, 1, 0.12
                                on_release: root.refresh_screen_data()

                    # ── Imprimir gráficos ─────────────────────────────
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(10)

                        ReportsAccentButton:
                            id: print_charts_button
                            text: 'Imprimir Graficos'
                            md_bg_color: app.theme_tokens['success']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.12
                            size_hint_x: None
                            width: dp(190)
                            on_release: root.print_productivity_charts()

                        Widget:

                    # ── Dashboard de produtividade ───────────────────
                    MDBoxLayout:
                        id: productivity_dashboard_host
                        orientation: 'vertical'
                        spacing: dp(0)
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                    # ── Título dos relatórios ────────────────────────
                    MDBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                        MDLabel:
                            text: 'Selecione o Tipo de Relatorio'
                            font_style: 'Subtitle1'
                            bold: True
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']
                            size_hint_y: None
                            height: dp(32)

                        MDLabel:
                            text: root.search_summary_text
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_y: None
                            height: dp(20)

                    # ── Grid de relatórios ───────────────────────────
                    MDGridLayout:
                        id: reports_grid
                        cols: 2
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                        ReportsReportButton:
                            id: sales_report_card
                            text: 'Relatorio de Vendas'
                            md_bg_color: app.theme_tokens['primary']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.14
                            on_release: root.generate_sales_report()

                        ReportsReportButton:
                            id: stock_report_card
                            text: 'Relatorio de Estoque'
                            md_bg_color: app.theme_tokens['success']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.14
                            on_release: root.generate_stock_report()

                        ReportsReportButton:
                            id: profit_report_card
                            text: 'Relatorio de Lucro'
                            md_bg_color: app.theme_tokens['warning']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.14
                            on_release: root.generate_profit_report()

                        ReportsReportButton:
                            id: complete_report_card
                            text: 'Relatorio Completo'
                            md_bg_color: app.theme_tokens['info']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.14
                            on_release: root.generate_complete_report()

                        ReportsReportButton:
                            id: cash_user_report_card
                            text: 'Caixa por Utilizador'
                            md_bg_color: app.theme_tokens['badge']
                            text_color: app.theme_tokens['on_primary']
                            hover_accent_color: [1, 1, 1, 1]
                            line_color: 1, 1, 1, 0.14
                            on_release: root.generate_cash_user_report()

                    # Estado vazio da pesquisa
                    ReportsPanelCard:
                        id: reports_empty_state
                        size_hint_y: None
                        height: 0
                        opacity: 0
                        disabled: True
                        padding: [dp(16), dp(16), dp(16), dp(16)]
                        md_bg_color: app.theme_tokens['card_alt']
                        radius: [dp(8)]
                        hover_enabled: False

                        MDLabel:
                            text: 'Nenhum relatorio combina com a pesquisa atual.'
                            halign: 'center'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']

                    Widget:
                        size_hint_y: None
                        height: dp(20)

        # ── AI FAB + badge ────────────────────────────────────────────
        MDFloatingActionButton:
            id: ai_button
            icon: "assets/icon/idea.ico"
            elevation: 2
            pos_hint: {"right": 0.965, "y": 0.04}
            on_release: root.open_ai_menu(self)

        MDCard:
            id: ai_badge
            size_hint: None, None
            size: dp(24), dp(24)
            md_bg_color: app.theme_tokens['badge']
            radius: [dp(12)]
            elevation: 1
            pos_hint: {"right": 0.978, "y": 0.098}
            opacity: 0

            MDLabel:
                id: ai_badge_label
                text: "0"
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: app.theme_tokens['on_primary']
                font_size: dp(12)
                bold: True

        FloatLayout:
            id: ai_banner_container
            size_hint: 1, 1
            pos: 0, 0
