<ReportsScreen>:
    name: 'reports'
    date_label: date_label
    product_spinner: product_spinner
    category_spinner: category_spinner

    FloatLayout:
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 0
            md_bg_color: app.theme_tokens['surface']

            MDCard:
                id: header_card
                size_hint_y: None
                height: dp(74)
                padding: [dp(25), dp(12), dp(25), dp(12)]
                spacing: dp(20)
                elevation: 2
                md_bg_color: app.theme_tokens['card']
                radius: [0, 0, 0, 0]

                MDBoxLayout:
                    id: header_content
                    spacing: dp(20)

                    MDBoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.7
                        spacing: dp(2)
                        adaptive_height: True

                        MDLabel:
                            text: 'Relatorios'
                            font_style: 'H5'
                            bold: True
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']
                            size_hint_y: None
                            height: dp(30)

                        MDLabel:
                            text: 'Analise e exportacao de dados'
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_y: None
                            height: dp(20)

                    MDBoxLayout:
                        id: header_actions
                        size_hint_x: 0.3
                        spacing: dp(10)
                        adaptive_height: True

                        MDRaisedButton:
                            id: hero_pdf_button
                            text: 'Todos PDFs'
                            size_hint_x: 0.36
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['primary']
                            elevation: 0
                            line_color: 0.15, 0.52, 0.76, 1
                            line_width: 1.5
                            on_release: root.show_pdf_viewer()

                        MDRaisedButton:
                            id: hero_refresh_button
                            text: 'Atualizar'
                            size_hint_x: 0.32
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['info']
                            elevation: 0
                            line_color: 0.28, 0.47, 0.84, 1
                            line_width: 1.5
                            on_release: root.refresh_screen_data()

                        MDRaisedButton:
                            id: hero_back_button
                            text: 'Voltar'
                            size_hint_x: 0.26
                            md_bg_color: app.theme_tokens['card']
                            text_color: app.theme_tokens['danger']
                            elevation: 0
                            line_color: 0.85, 0.3, 0.3, 1
                            line_width: 1.5
                            on_release: root.go_back()

            ScrollView:
                do_scroll_x: False
                do_scroll_y: True

                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(20)
                    padding: [dp(25), dp(20), dp(25), dp(25)]
                    size_hint_y: None
                    height: self.minimum_height

                    MDCard:
                        id: filters_card
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(0)
                        padding: [dp(25), dp(20), dp(25), dp(20)]
                        elevation: 1
                        md_bg_color: app.theme_tokens['card']
                        radius: [dp(8)]

                        MDLabel:
                            text: 'Configurar Filtros'
                            font_style: 'H6'
                            bold: True
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']
                            size_hint_y: None
                            height: dp(34)

                        MDLabel:
                            text: 'Mantenha a tela familiar e encontre o relatorio certo mais rapido.'
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_y: None
                            height: dp(20)

                        Widget:
                            size_hint_y: None
                            height: dp(10)

                        MDBoxLayout:
                            id: search_row
                            size_hint_y: None
                            height: self.minimum_height
                            adaptive_height: True
                            spacing: dp(12)

                            MDTextField:
                                id: report_search_input
                                hint_text: 'Pesquisar relatorio, produto ou categoria'
                                mode: 'rectangle'
                                icon_left: 'magnify'
                                on_text: root.on_search(self.text)
                                on_text_validate: root.on_search_enter()

                            MDRaisedButton:
                                id: search_clear_button
                                text: 'Limpar'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['text_primary']
                                elevation: 0
                                on_release: root.clear_search()

                        Widget:
                            size_hint_y: None
                            height: dp(4)

                        MDLabel:
                            text: root.search_status_text
                            font_style: 'Caption'
                            halign: 'left'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]

                        Widget:
                            size_hint_y: None
                            height: dp(12)

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(60)
                            spacing: dp(15)
                            adaptive_height: True

                            MDBoxLayout:
                                orientation: 'vertical'
                                size_hint_x: 0.65
                                spacing: dp(6)
                                adaptive_height: True

                                MDLabel:
                                    text: 'Periodo do Relatorio'
                                    font_style: 'Subtitle2'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(20)

                                MDLabel:
                                    id: date_label
                                    text: 'Nenhum periodo selecionado'
                                    font_style: 'Body2'
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(25)

                            MDRaisedButton:
                                text: 'Selecionar Periodo'
                                size_hint_x: 0.35
                                md_bg_color: app.theme_tokens['warning']
                                text_color: app.theme_tokens['on_primary']
                                elevation: 2
                                on_release: root.select_date_range()

                        Widget:
                            size_hint_y: None
                            height: dp(10)

                        MDGridLayout:
                            id: quick_range_grid
                            cols: 4
                            spacing: dp(10)
                            size_hint_y: None
                            height: self.minimum_height
                            adaptive_height: True

                            MDRaisedButton:
                                text: 'Hoje'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['warning']
                                elevation: 0
                                on_release: root.apply_today_range()

                            MDRaisedButton:
                                text: '7 Dias'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['primary']
                                elevation: 0
                                on_release: root.apply_last_days_range(7)

                            MDRaisedButton:
                                text: '30 Dias'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['success']
                                elevation: 0
                                on_release: root.apply_last_days_range(30)

                            MDRaisedButton:
                                text: 'Este Mes'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['info']
                                elevation: 0
                                on_release: root.apply_current_month_range()

                        Widget:
                            size_hint_y: None
                            height: dp(12)

                        MDGridLayout:
                            id: filters_grid
                            cols: 2
                            spacing: dp(12)
                            size_hint_y: None
                            height: self.minimum_height
                            adaptive_height: True

                            MDBoxLayout:
                                size_hint_y: None
                                height: dp(65)
                                spacing: dp(0)
                                orientation: 'vertical'
                                adaptive_height: True

                                MDLabel:
                                    text: 'Produto'
                                    font_style: 'Subtitle2'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(20)

                                MDRaisedButton:
                                    id: product_spinner
                                    text: 'Todos os Produtos'
                                    md_bg_color: app.theme_tokens['card_alt']
                                    text_color: app.theme_tokens['text_primary']
                                    elevation: 0
                                    on_release: root.open_product_menu(self)

                            MDBoxLayout:
                                size_hint_y: None
                                height: dp(65)
                                spacing: dp(0)
                                orientation: 'vertical'
                                adaptive_height: True

                                MDLabel:
                                    text: 'Categoria'
                                    font_style: 'Subtitle2'
                                    bold: True
                                    halign: 'left'
                                    theme_text_color: 'Custom'
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(20)

                                MDRaisedButton:
                                    id: category_spinner
                                    text: 'Todas as Categorias'
                                    md_bg_color: app.theme_tokens['card_alt']
                                    text_color: app.theme_tokens['text_primary']
                                    elevation: 0
                                    on_release: root.open_category_menu(self)

                        Widget:
                            size_hint_y: None
                            height: dp(12)

                        MDBoxLayout:
                            id: filter_actions
                            size_hint_y: None
                            height: dp(40)
                            spacing: dp(10)

                            MDRaisedButton:
                                id: filter_reset_button
                                text: 'Limpar Filtros'
                                md_bg_color: app.theme_tokens['card_alt']
                                text_color: app.theme_tokens['text_primary']
                                elevation: 0
                                on_release: root.reset_filters()

                            MDRaisedButton:
                                id: filter_refresh_button
                                text: 'Atualizar Dados'
                                md_bg_color: app.theme_tokens['info']
                                text_color: app.theme_tokens['on_primary']
                                elevation: 1
                                on_release: root.refresh_screen_data()

                    Widget:
                        size_hint_y: None
                        height: dp(10)

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(10)

                        MDRaisedButton:
                            id: print_charts_button
                            text: 'Imprimir Graficos'
                            md_bg_color: app.theme_tokens['success']
                            text_color: app.theme_tokens['on_primary']
                            elevation: 1
                            size_hint_x: None
                            width: dp(190)
                            on_release: root.print_productivity_charts()

                        Widget:

                    Widget:
                        size_hint_y: None
                        height: dp(6)

                    MDBoxLayout:
                        id: productivity_dashboard_host
                        orientation: 'vertical'
                        spacing: dp(0)
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                    MDLabel:
                        text: 'Selecione o Tipo de Relatorio'
                        font_style: 'Subtitle1'
                        bold: True
                        halign: 'left'
                        theme_text_color: 'Custom'
                        text_color: app.theme_tokens['text_primary']
                        size_hint_y: None
                        height: dp(35)

                    MDLabel:
                        text: root.search_summary_text
                        font_style: 'Caption'
                        halign: 'left'
                        theme_text_color: 'Custom'
                        text_color: app.theme_tokens['text_secondary']
                        size_hint_y: None
                        height: dp(20)

                    MDGridLayout:
                        id: reports_grid
                        cols: 2
                        spacing: dp(15)
                        size_hint_y: None
                        height: self.minimum_height
                        adaptive_height: True

                        MDRaisedButton:
                            id: sales_report_card
                            text: 'Relatorio de Vendas'
                            size_hint_y: None
                            height: dp(92)
                            md_bg_color: app.theme_tokens['primary']
                            text_color: app.theme_tokens['on_primary']
                            font_size: sp(15)
                            elevation: 3
                            on_release: root.generate_sales_report()

                        MDRaisedButton:
                            id: stock_report_card
                            text: 'Relatorio de Estoque'
                            size_hint_y: None
                            height: dp(92)
                            md_bg_color: app.theme_tokens['success']
                            text_color: app.theme_tokens['on_primary']
                            font_size: sp(15)
                            elevation: 3
                            on_release: root.generate_stock_report()

                        MDRaisedButton:
                            id: profit_report_card
                            text: 'Relatorio de Lucro'
                            size_hint_y: None
                            height: dp(92)
                            md_bg_color: app.theme_tokens['warning']
                            text_color: app.theme_tokens['on_primary']
                            font_size: sp(15)
                            elevation: 3
                            on_release: root.generate_profit_report()

                        MDRaisedButton:
                            id: complete_report_card
                            text: 'Relatorio Completo'
                            size_hint_y: None
                            height: dp(92)
                            md_bg_color: app.theme_tokens['info']
                            text_color: app.theme_tokens['on_primary']
                            font_size: sp(15)
                            elevation: 3
                            on_release: root.generate_complete_report()

                    MDCard:
                        id: reports_empty_state
                        size_hint_y: None
                        height: 0
                        opacity: 0
                        disabled: True
                        padding: [dp(16), dp(16), dp(16), dp(16)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['card_alt']
                        radius: [dp(8)]

                        MDLabel:
                            text: 'Nenhum relatorio combina com a pesquisa atual.'
                            halign: 'center'
                            theme_text_color: 'Custom'
                            text_color: app.theme_tokens['text_primary']

                    Widget:
                        size_hint_y: None
                        height: dp(20)

        FloatLayout:
            id: ai_banner_container
            size_hint: 1, 1
            pos: 0, 0

        MDFloatingActionButton:
            id: ai_button
            icon: "assets/icon/idea.ico"
            elevation: 2
            pos_hint: {"right": 0.965, "y": 0.04}
            on_release: root.open_ai_menu(self)

        MDCard:
            id: ai_badge
            size_hint: None, None
            size: dp(24), dp(24)
            md_bg_color: app.theme_tokens['badge']
            radius: [dp(12)]
            elevation: 1
            pos_hint: {"right": 0.978, "y": 0.098}
            opacity: 0

            MDLabel:
                id: ai_badge_label
                text: "0"
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: app.theme_tokens['on_primary']
                font_size: dp(12)
                bold: True
