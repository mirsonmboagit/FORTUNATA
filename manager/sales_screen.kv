#:kivy 2.0

<QuickProductCard>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(78)
    padding: [dp(10), dp(8), dp(10), dp(8)]
    spacing: dp(10)
    radius: [dp(12)]
    elevation: 1
    md_bg_color: app.theme_tokens['card']

    MDCard:
        size_hint: None, None
        size: dp(44), dp(44)
        radius: [dp(10)]
        elevation: 0
        md_bg_color: app.theme_tokens['card_alt']

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            MDIcon:
                id: product_icon
                icon: "package-variant-closed"
                size_hint: None, None
                size: dp(22), dp(22)
                text_size: self.size
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: app.theme_tokens['info']
                font_size: dp(22)

    MDBoxLayout:
        orientation: "vertical"
        spacing: dp(2)

        MDLabel:
            id: product_name_label
            text: ""
            bold: True
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: app.theme_tokens['text_primary']
            shorten: True
            shorten_from: "right"

        MDLabel:
            id: product_meta_label
            text: ""
            font_size: dp(10)
            theme_text_color: "Custom"
            text_color: app.theme_tokens['text_secondary']
            shorten: True
            shorten_from: "right"

    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: None
        width: dp(92)
        spacing: dp(1)

        MDLabel:
            id: product_price_label
            text: ""
            halign: "right"
            bold: True
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: app.theme_tokens['success']

        MDLabel:
            id: product_mode_label
            text: ""
            halign: "right"
            font_size: dp(10)
            theme_text_color: "Custom"
            text_color: app.theme_tokens['text_secondary']

    MDBoxLayout:
        orientation: "horizontal"
        size_hint_x: None
        width: dp(92)
        spacing: dp(6)

        TooltipIconButton:
            id: add_unit_btn
            icon: "plus"
            icon_size: sp(18)
            theme_text_color: "Custom"
            text_color: app.theme_tokens['on_primary']
            md_bg_color: app.theme_tokens['primary']
            hint_text: "Adicionar unidade | Enter na pesquisa"
            on_release: root.on_add_unit_click()

        TooltipIconButton:
            id: add_pack_btn
            icon: "package-variant-closed-plus"
            icon_size: sp(18)
            theme_text_color: "Custom"
            text_color: app.theme_tokens['on_primary']
            md_bg_color: app.theme_tokens['success']
            hint_text: "Adicionar embalagem"
            on_release: root.on_add_pack_click()


<FloatingScannerPanel>:
    orientation: "vertical"
    size_hint: None, None
    size: dp(296), dp(320)
    radius: [dp(12)]
    elevation: 4
    md_bg_color: app.theme_tokens['surface'][0], app.theme_tokens['surface'][1], app.theme_tokens['surface'][2], 0.98
    padding: [dp(10), dp(10), dp(10), dp(10)]
    spacing: dp(8)
    opacity: 0
    disabled: True

    MDBoxLayout:
        size_hint_y: None
        height: dp(28)
        spacing: dp(8)

        MDLabel:
            text: "Scanner flutuante"
            bold: True
            font_size: dp(12)
            theme_text_color: "Custom"
            text_color: app.theme_tokens['text_primary']

        Widget:

    AnchorLayout:
        anchor_x: "center"
        anchor_y: "center"

        MDCard:
            size_hint: None, None
            size: max(dp(128), min(root.width - dp(20), root.height - dp(116))), max(dp(128), min(root.width - dp(20), root.height - dp(116)))
            radius: [dp(16)]
            elevation: 0
            md_bg_color: app.theme_tokens['card_alt']

            Image:
                id: camera_image
                fit_mode: "fill"

    MDLabel:
        id: scanner_status_label
        size_hint_y: None
        height: dp(18)
        text: "A preparar a camera..."
        font_size: dp(11)
        shorten: True
        shorten_from: "right"
        theme_text_color: "Custom"
        text_color: app.theme_tokens['text_secondary']

    MDBoxLayout:
        size_hint_y: None
        height: dp(36)
        spacing: dp(8)

        MDRaisedButton:
            text: "Parar"
            md_bg_color: app.theme_tokens['danger']
            on_release: app.root.get_screen("manager").toggle_scanner() if app.root and "manager" in app.root.screen_names else None

        MDRaisedButton:
            text: "Trocar Cam"
            md_bg_color: app.theme_tokens['primary']
            on_release: app.root.get_screen("manager").switch_camera() if app.root and "manager" in app.root.screen_names else None


<SalesScreen>:
    name: "manager"
    md_bg_color: app.theme_tokens['surface']

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(12), dp(12), dp(12), dp(12)]
        spacing: dp(10)

        MDCard:
            size_hint_y: None
            height: dp(72)
            radius: [dp(12)]
            elevation: 2
            md_bg_color: app.theme_tokens['card']
            padding: [dp(16), dp(10), dp(16), dp(10)]

            MDBoxLayout:
                spacing: dp(14)

                MDBoxLayout:
                    size_hint_x: 0.40
                    spacing: dp(12)

                    MDCard:
                        size_hint: None, None
                        size: dp(48), dp(48)
                        radius: [dp(10)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['primary']

                        AnchorLayout:
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                icon: "storefront-outline"
                                size_hint: None, None
                                size: dp(26), dp(26)
                                text_size: self.size
                                halign: "center"
                                valign: "middle"
                                font_size: dp(26)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['on_primary']

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "{} - POS".format(app.system_name)
                            bold: True
                            font_style: "H6"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                        MDLabel:
                            text: "Caixa de vendas profissional"
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']

                MDBoxLayout:
                    size_hint_x: 0.30
                    spacing: dp(12)

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "Operador"
                            font_size: dp(10)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                        MDLabel:
                            id: operator_label
                            text: root.operator_name
                            bold: True
                            font_style: "Subtitle1"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "Atualizado"
                            font_size: dp(10)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                        MDLabel:
                            id: datetime_label
                            text: root.header_datetime_text
                            bold: True
                            font_style: "Subtitle2"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                MDBoxLayout:
                    size_hint_x: 0.30
                    spacing: dp(8)

                    Widget:

                    MDCard:
                        size_hint: None, None
                        size: dp(126), dp(42)
                        radius: [dp(16)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['success'][0], app.theme_tokens['success'][1], app.theme_tokens['success'][2], 0.16
                        padding: [dp(12), 0, dp(12), 0]

                        MDBoxLayout:
                            spacing: dp(8)

                            AnchorLayout:
                                size_hint_x: None
                                width: dp(20)
                                anchor_x: "center"
                                anchor_y: "center"

                                MDCard:
                                    size_hint: None, None
                                    size: dp(14), dp(14)
                                    radius: [dp(7)]
                                    elevation: 0
                                    md_bg_color: app.theme_tokens['success']

                            MDLabel:
                                id: connection_label
                                text: "Online"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['success']

                    TooltipIconButton:
                        icon: "history"
                        icon_size: sp(20)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_primary']
                        md_bg_color: app.theme_tokens['card_alt']
                        hint_text: "Historico de vendas | Ctrl+H"
                        on_release: root.open_sales_history()

                    TooltipIconButton:
                        icon: "alert-circle-outline"
                        icon_size: sp(20)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_primary']
                        md_bg_color: app.theme_tokens['card_alt']
                        hint_text: "Registar perdas | Ctrl+D"
                        on_release: root.open_losses_screen()

                    TooltipIconButton:
                        icon: "refresh"
                        icon_size: sp(20)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_primary']
                        md_bg_color: app.theme_tokens['card_alt']
                        hint_text: "Atualizar painel | Ctrl+R"
                        on_release: root.refresh_products_panel()

                    TooltipIconButton:
                        icon: "logout"
                        icon_size: sp(20)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_primary']
                        md_bg_color: app.theme_tokens['danger'][0], app.theme_tokens['danger'][1], app.theme_tokens['danger'][2], 0.22
                        hint_text: "Terminar sessao | Ctrl+Backspace"
                        on_release: root.return_to_login()

        MDBoxLayout:
            id: notices_bar
            size_hint_y: None
            height: max(notice_one_card.height, notice_two_card.height, notice_three_card.height)
            spacing: dp(8)

            NoticeBannerCard:
                id: notice_one_card
                orientation: "vertical"
                size_hint_y: None
                height: dp(50) + notice_one_details_shell.height
                radius: [dp(12)]
                elevation: 0
                md_bg_color: app.theme_tokens['card']
                padding: [dp(0), dp(0), dp(10), dp(0)]
                on_touch_up:
                    if self.collide_point(*args[1].pos): root.open_notice_detail("one")

                MDBoxLayout:
                    id: notice_one_main_row
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(0)

                    MDBoxLayout:
                        size_hint_x: None
                        width: dp(4)
                        canvas.before:
                            Color:
                                rgba: app.theme_tokens['warning']
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12), dp(0), dp(0), dp(12)]

                    MDBoxLayout:
                        spacing: dp(6)
                        padding: [dp(10), dp(6), dp(0), dp(6)]

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(24)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_one_icon
                                icon: "alert-outline"
                                size_hint: None, None
                                size: dp(18), dp(18)
                                text_size: self.size
                                halign: "center"
                                valign: "middle"
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['warning']
                                font_size: dp(18)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(2)

                            MDLabel:
                                id: notice_one_title
                                text: "Stock sob controlo"
                                bold: True
                                font_size: dp(11)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']

                            MDLabel:
                                id: notice_one_body
                                text: "Sem alertas criticos no momento."
                                font_size: dp(10)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(26)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_one_toggle_icon
                                icon: "chevron-right"
                                halign: "center"
                                font_size: dp(18)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                MDBoxLayout:
                    id: notice_one_details_shell
                    size_hint_y: None
                    height: 0
                    opacity: 0
                    padding: [dp(14), 0, dp(14), dp(10)]

                    MDLabel:
                        id: notice_one_detail_body
                        text: ""
                        font_size: dp(10)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_secondary']
                        valign: "top"
                        text_size: self.width, None
                        size_hint_y: None
                        height: self.texture_size[1]

            NoticeBannerCard:
                id: notice_two_card
                orientation: "vertical"
                size_hint_y: None
                height: dp(50) + notice_two_details_shell.height
                radius: [dp(12)]
                elevation: 0
                md_bg_color: app.theme_tokens['card']
                padding: [dp(0), dp(0), dp(10), dp(0)]
                on_touch_up:
                    if self.collide_point(*args[1].pos): root.open_notice_detail("two")

                MDBoxLayout:
                    id: notice_two_main_row
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(0)

                    MDBoxLayout:
                        size_hint_x: None
                        width: dp(4)
                        canvas.before:
                            Color:
                                rgba: app.theme_tokens['info']
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12), dp(0), dp(0), dp(12)]

                    MDBoxLayout:
                        spacing: dp(6)
                        padding: [dp(10), dp(6), dp(0), dp(6)]

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(24)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_two_icon
                                icon: "chart-line"
                                size_hint: None, None
                                size: dp(18), dp(18)
                                text_size: self.size
                                halign: "center"
                                valign: "middle"
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['info']
                                font_size: dp(18)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(2)

                            MDLabel:
                                id: notice_two_title
                                text: "Produto do dia"
                                bold: True
                                font_size: dp(11)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']

                            MDLabel:
                                id: notice_two_body
                                text: "Ainda sem destaque hoje."
                                font_size: dp(10)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(26)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_two_toggle_icon
                                icon: "chevron-right"
                                halign: "center"
                                font_size: dp(18)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                MDBoxLayout:
                    id: notice_two_details_shell
                    size_hint_y: None
                    height: 0
                    opacity: 0
                    padding: [dp(14), 0, dp(14), dp(10)]

                    MDLabel:
                        id: notice_two_detail_body
                        text: ""
                        font_size: dp(10)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_secondary']
                        valign: "top"
                        text_size: self.width, None
                        size_hint_y: None
                        height: self.texture_size[1]

            NoticeBannerCard:
                id: notice_three_card
                orientation: "vertical"
                size_hint_y: None
                height: dp(50) + notice_three_details_shell.height
                radius: [dp(12)]
                elevation: 0
                md_bg_color: app.theme_tokens['card']
                padding: [dp(0), dp(0), dp(10), dp(0)]
                on_touch_up:
                    if self.collide_point(*args[1].pos): root.open_notice_detail("three")

                MDBoxLayout:
                    id: notice_three_main_row
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(0)

                    MDBoxLayout:
                        size_hint_x: None
                        width: dp(4)
                        canvas.before:
                            Color:
                                rgba: app.theme_tokens['success']
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12), dp(0), dp(0), dp(12)]

                    MDBoxLayout:
                        spacing: dp(8)
                        padding: [dp(10), dp(6), dp(0), dp(6)]

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(24)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_three_icon
                                icon: "clock-outline"
                                size_hint: None, None
                                size: dp(18), dp(18)
                                text_size: self.size
                                halign: "center"
                                valign: "middle"
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['success']
                                font_size: dp(18)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(2)

                            MDLabel:
                                id: notice_three_title
                                text: "Pico operacional"
                                bold: True
                                font_size: dp(11)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']

                            MDLabel:
                                id: notice_three_body
                                text: "Sem dados suficientes ainda."
                                font_size: dp(10)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                        AnchorLayout:
                            size_hint_x: None
                            width: dp(26)
                            anchor_x: "center"
                            anchor_y: "center"

                            MDIcon:
                                id: notice_three_toggle_icon
                                icon: "chevron-right"
                                halign: "center"
                                font_size: dp(18)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                MDBoxLayout:
                    id: notice_three_details_shell
                    size_hint_y: None
                    height: 0
                    opacity: 0
                    padding: [dp(14), 0, dp(14), dp(10)]

                    MDLabel:
                        id: notice_three_detail_body
                        text: ""
                        font_size: dp(10)
                        theme_text_color: "Custom"
                        text_color: app.theme_tokens['text_secondary']
                        valign: "top"
                        text_size: self.width, None
                        size_hint_y: None
                        height: self.texture_size[1]

        MDBoxLayout:
            id: body_shell
            orientation: "horizontal"
            spacing: dp(10)

            MDCard:
                id: workspace_card
                size_hint_x: 0.35
                radius: [dp(18)]
                elevation: 2
                md_bg_color: app.theme_tokens['surface_alt']
                padding: [dp(12), dp(12), dp(12), dp(12)]

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(28)

                        MDLabel:
                            text: "Pesquisa de produtos"
                            bold: True
                            font_style: "H6"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                        MDLabel:
                            id: product_results_label
                            text: "0 produtos"
                            halign: "right"
                            font_size: dp(10)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']

                    MDCard:
                        id: search_shell_card
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [dp(12), dp(12), dp(12), dp(12)]
                        spacing: dp(8)
                        radius: [dp(16)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['card_alt']

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(54)
                            spacing: dp(8)

                            MDCard:
                                size_hint: None, None
                                size: dp(44), dp(44)
                                radius: [dp(14)]
                                elevation: 0
                                md_bg_color: app.theme_tokens['card_alt']

                                AnchorLayout:
                                    anchor_x: "center"
                                    anchor_y: "center"

                                    MDIcon:
                                        icon: "barcode-scan"
                                        size_hint: None, None
                                        size: dp(24), dp(24)
                                        text_size: self.size
                                        halign: "center"
                                        valign: "middle"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['success']
                                        font_size: dp(24)

                            MDTextField:
                                id: search_input
                                hint_text: "Escaneie ou pesquise produto"
                                mode: "rectangle"
                                multiline: False
                                font_size: dp(10)
                                line_color_normal: app.theme_tokens['divider']
                                line_color_focus: app.theme_tokens['primary']
                                text_color_normal: app.theme_tokens['text_primary']
                                text_color_focus: app.theme_tokens['text_primary']
                                hint_text_color_normal: 0.58, 0.62, 0.71, 1
                                on_text: root.on_search(self.text)
                                on_text_validate: root.on_search_enter()

                            TooltipIconButton:
                                id: clear_search_btn
                                icon: "close"
                                icon_size: sp(20)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']
                                md_bg_color: app.theme_tokens['card_alt']
                                hint_text: "Limpar pesquisa | Ctrl+L"
                                on_release: root.clear_search()

                            TooltipIconButton:
                                id: scan_toggle_btn
                                icon: "barcode-scan"
                                icon_size: sp(20)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['on_primary']
                                md_bg_color: app.theme_tokens['success']
                                hint_text: "Ligar ou desligar scanner | Ctrl+B"
                                on_release: root.toggle_scanner()

                        MDCard:
                            id: search_feedback_card
                            size_hint_y: None
                            height: dp(34)
                            radius: [dp(12)]
                            elevation: 0
                            md_bg_color: app.theme_tokens['success'][0], app.theme_tokens['success'][1], app.theme_tokens['success'][2], 0.18
                            padding: [dp(10), 0, dp(10), 0]

                            MDBoxLayout:
                                spacing: dp(8)

                                AnchorLayout:
                                    size_hint_x: None
                                    width: dp(20)
                                    anchor_x: "center"
                                    anchor_y: "center"

                                    MDIcon:
                                        id: search_feedback_icon
                                        icon: "check-circle"
                                        size_hint: None, None
                                        size: dp(16), dp(16)
                                        text_size: self.size
                                        halign: "center"
                                        valign: "middle"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['success']
                                        font_size: dp(16)

                                MDLabel:
                                    id: search_feedback_label
                                    text: "Pronto para vender"
                                    font_size: dp(11)
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_primary']

                        MDLabel:
                            id: physical_scanner_status_label
                            text: "Scanner USB pronto para leitura"
                            size_hint_y: None
                            height: dp(18)
                            font_size: dp(10)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            shorten: True
                            shorten_from: "right"

                        MDCard:
                            id: scanner_preview_card_inline
                            orientation: "horizontal"
                            size_hint_y: None
                            height: 0
                            opacity: 0
                            radius: [dp(14)]
                            elevation: 0
                            md_bg_color: app.theme_tokens['surface_alt']
                            padding: [dp(8), dp(8), dp(8), dp(8)]
                            spacing: dp(10)

                            MDCard:
                                size_hint_x: None
                                width: dp(148)
                                radius: [dp(12)]
                                elevation: 0
                                md_bg_color: app.theme_tokens['card_alt']

                                Image:
                                    id: camera_image_inline
                                    fit_mode: "contain"

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: dp(6)

                                MDLabel:
                                    text: "Scanner compacto ativo"
                                    bold: True
                                    font_style: "Subtitle2"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_primary']

                                MDLabel:
                                    id: scanner_status_label_inline
                                    text: "A preparar a camera..."
                                    font_size: dp(11)
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']

                                MDBoxLayout:
                                    size_hint_y: None
                                    height: dp(36)
                                    spacing: dp(8)

                                    TooltipRaisedButton:
                                        text: "Parar"
                                        tooltip_text: "Parar scanner | Ctrl+B"
                                        md_bg_color: app.theme_tokens['danger']
                                        on_release: root.toggle_scanner()

                                    TooltipRaisedButton:
                                        text: "Cam"
                                        tooltip_text: "Trocar camera | Ctrl+K"
                                        md_bg_color: app.theme_tokens['primary']
                                        on_release: root.switch_camera()

                    MDCard:
                        id: product_results_card
                        orientation: "vertical"
                        radius: [dp(14)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['surface_alt']
                        padding: [dp(10), dp(10), dp(10), dp(10)]
                        spacing: dp(8)

                        RecycleView:
                            id: product_matches_rv
                            viewclass: "RecycleQuickProductCard"
                            scroll_type: ["bars", "content"]
                            bar_width: dp(6)
                            do_scroll_x: False
                            on_scroll_y: root.on_products_scroll(self.scroll_y)

                            RecycleBoxLayout:
                                default_size: None, dp(78)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: "vertical"
                                spacing: dp(8)

            MDCard:
                id: cart_card
                size_hint_x: 0.40
                radius: [dp(18)]
                elevation: 2
                md_bg_color: app.theme_tokens['surface_alt']
                padding: [dp(12), dp(12), dp(12), dp(12)]

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(34)
                        spacing: dp(8)

                        MDLabel:
                            text: "Itens da venda"
                            bold: True
                            font_style: "H6"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                        MDLabel:
                            id: cart_count_label
                            text: "0 itens"
                            halign: "right"
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(34)
                        spacing: dp(6)
                        padding: [dp(10), 0, dp(8), 0]

                        canvas.before:
                            Color:
                                rgba: app.theme_tokens['card_alt']
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(10), dp(10), dp(10), dp(10)]

                        MDLabel:
                            text: "Produto"
                            bold: True
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_x: 0.42

                        MDLabel:
                            text: "Qtd"
                            halign: "center"
                            bold: True
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_x: 0.22

                        MDLabel:
                            text: "Preco"
                            halign: "right"
                            bold: True
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_x: 0.16

                        MDLabel:
                            text: "Total"
                            halign: "right"
                            bold: True
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            size_hint_x: 0.14

                        MDLabel:
                            text: ""
                            size_hint_x: 0.06

                    MDBoxLayout:
                        orientation: "vertical"

                        ScrollView:
                            do_scroll_x: False

                            MDBoxLayout:
                                id: cart_list
                                orientation: "vertical"
                                adaptive_height: True
                                spacing: dp(8)
                                padding: [0, dp(4), 0, dp(4)]

                        MDLabel:
                            id: cart_empty_label
                            text: "O carrinho ainda esta vazio.\nUse a pesquisa ou o scanner para adicionar produtos."
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']
                            font_size: dp(12)
                            size_hint_y: None
                            height: dp(60)

            MDCard:
                id: summary_card
                size_hint_x: 0.25
                radius: [dp(18)]
                elevation: 2
                md_bg_color: app.theme_tokens['surface_alt']
                padding: [dp(12), dp(12), dp(12), dp(12)]
                spacing: dp(10)

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(46)
                        spacing: dp(8)

                        MDCard:
                            size_hint: None, None
                            size: dp(42), dp(42)
                            radius: [dp(14)]
                            elevation: 0
                            md_bg_color: app.theme_tokens['primary'][0], app.theme_tokens['primary'][1], app.theme_tokens['primary'][2], 0.16

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                MDIcon:
                                    icon: "receipt-text-check-outline"
                                    size_hint: None, None
                                    size: dp(22), dp(22)
                                    text_size: self.size
                                    halign: "center"
                                    valign: "middle"
                                    font_size: dp(22)
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['primary']

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(1)

                            MDLabel:
                                text: "Resumo da venda"
                                bold: True
                                font_style: "Subtitle1"
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']

                            MDLabel:
                                text: "Totais, pagamento e troco"
                                font_size: dp(10)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                    MDCard:
                        orientation: "vertical"
                        size_hint_y: None
                        height: dp(104)
                        radius: [dp(16)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['card']
                        padding: [dp(12), dp(10), dp(12), dp(10)]
                        spacing: dp(8)

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(24)

                            MDLabel:
                                text: "Subtotal"
                                font_size: dp(12)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                            MDLabel:
                                id: subtotal_value_label
                                text: "0.00 MT"
                                halign: "right"
                                bold: True
                                font_size: dp(13)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_primary']

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(40)
                            spacing: dp(8)

                            MDLabel:
                                text: "Desconto"
                                size_hint_x: 0.32
                                font_size: dp(12)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                            TooltipTextField:
                                id: discount_input
                                hint_text: "0.00"
                                tooltip_text: "Desconto | Alt+D"
                                multiline: False
                                input_filter: "float"
                                mode: "rectangle"
                                size_hint_x: 0.38
                                font_size: dp(12)
                                line_color_normal: app.theme_tokens['divider']
                                line_color_focus: app.theme_tokens['primary']
                                on_text: root.on_discount_text(self.text)

                            MDLabel:
                                id: discount_value_label
                                text: "0.00 MT"
                                halign: "right"
                                size_hint_x: 0.30
                                bold: True
                                font_size: dp(12)
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['success']

                    MDCard:
                        id: total_final_card
                        size_hint_y: None
                        height: dp(64)
                        radius: [dp(16)]
                        elevation: 0
                        ripple_behavior: True
                        md_bg_color: app.theme_tokens['success'][0], app.theme_tokens['success'][1], app.theme_tokens['success'][2], 0.24
                        padding: [dp(14), dp(9), dp(14), dp(9)]
                        on_touch_up: root.on_total_final_card_touch(self, args[1])

                        MDBoxLayout:
                            spacing: dp(10)

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: dp(2)

                                MDLabel:
                                    text: "Total final"
                                    font_size: dp(11)
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']

                                MDLabel:
                                    id: total_value_label
                                    text: "0.00 MT"
                                    bold: True
                                    font_style: "H5"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_primary']

                            AnchorLayout:
                                size_hint_x: None
                                width: dp(34)
                                anchor_x: "center"
                                anchor_y: "center"

                                MDIcon:
                                    icon: "gesture-tap-button"
                                    size_hint: None, None
                                    size: dp(22), dp(22)
                                    text_size: self.size
                                    halign: "center"
                                    valign: "middle"
                                    font_size: dp(22)
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['success']

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(18)

                        MDLabel:
                            text: "Forma de pagamento"
                            font_size: dp(11)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                        MDLabel:
                            text: "Alt+1..4"
                            halign: "right"
                            font_size: dp(10)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(36)
                        spacing: dp(5)

                        TooltipRaisedButton:
                            id: pay_cash_btn
                            text: "Dinheiro"
                            tooltip_text: "Pagamento em dinheiro | Alt+1"
                            font_size: dp(10)
                            size_hint_y: None
                            height: dp(36)
                            md_bg_color: app.theme_tokens['success']
                            on_release: root.set_payment_method("cash")

                        TooltipRaisedButton:
                            id: pay_card_btn
                            text: "Cartao"
                            tooltip_text: "Pagamento com cartao | Alt+2"
                            font_size: dp(10)
                            size_hint_y: None
                            height: dp(36)
                            md_bg_color: app.theme_tokens['card_alt']
                            on_release: root.set_payment_method("card")

                        TooltipRaisedButton:
                            id: pay_mobile_btn
                            text: "M-Pesa"
                            tooltip_text: "Pagamento M-Pesa | Alt+3"
                            font_size: dp(10)
                            size_hint_y: None
                            height: dp(36)
                            md_bg_color: app.theme_tokens['card_alt']
                            on_release: root.set_payment_method("mobile")

                        TooltipRaisedButton:
                            id: pay_emola_btn
                            text: "E-MOLA"
                            tooltip_text: "Pagamento E-MOLA | Alt+4"
                            font_size: dp(10)
                            size_hint_y: None
                            height: dp(36)
                            md_bg_color: app.theme_tokens['card_alt']
                            on_release: root.set_payment_method("emola")

                    MDCard:
                        orientation: "vertical"
                        size_hint_y: None
                        height: dp(92)
                        radius: [dp(16)]
                        elevation: 0
                        md_bg_color: app.theme_tokens['card']
                        padding: [dp(12), dp(10), dp(12), dp(10)]
                        spacing: dp(8)

                        MDLabel:
                            text: "Recebimento"
                            size_hint_y: None
                            height: dp(18)
                            bold: True
                            font_size: dp(11)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            spacing: dp(8)

                            TooltipTextField:
                                id: paid_input
                                hint_text: "Valor pago"
                                tooltip_text: "Valor pago | Alt+V"
                                multiline: False
                                input_filter: "float"
                                mode: "rectangle"
                                font_size: dp(12)
                                line_color_normal: app.theme_tokens['divider']
                                line_color_focus: app.theme_tokens['primary']
                                on_text: root.calculate_change()

                            MDCard:
                                size_hint_x: 0.46
                                radius: [dp(12)]
                                elevation: 0
                                md_bg_color: app.theme_tokens['success'][0], app.theme_tokens['success'][1], app.theme_tokens['success'][2], 0.13
                                padding: [dp(10), dp(5), dp(10), dp(5)]

                                MDBoxLayout:
                                    orientation: "vertical"
                                    spacing: dp(1)

                                    MDLabel:
                                        text: "Troco"
                                        font_size: dp(10)
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['text_secondary']

                                    MDLabel:
                                        id: change_value_label
                                        text: "0.00 MT"
                                        bold: True
                                        font_style: "Subtitle1"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['success']

                    Widget:

        AnchorLayout:
            anchor_x: "right"
            anchor_y: "center"
            size_hint_y: None
            height: action_group_card.height

            MDCard:
                id: action_group_card
                size_hint: None, None
                width: bottom_actions_grid.minimum_width + dp(24)
                height: bottom_actions_content.minimum_height + dp(20)
                radius: [dp(18)]
                elevation: 2
                md_bg_color: app.theme_tokens['card']
                padding: [dp(12), dp(10), dp(12), dp(10)]

                MDBoxLayout:
                    id: bottom_actions_content
                    orientation: "vertical"
                    spacing: dp(6)

                    MDGridLayout:
                        id: bottom_actions_grid
                        cols: 4
                        spacing: dp(8)
                        size_hint: None, None
                        width: self.minimum_width
                        height: self.minimum_height

                        TooltipRaisedButton:
                            id: finalize_btn
                            text: "Finalizar"
                            tooltip_text: "Finalizar venda | Ctrl+Enter"
                            size_hint: None, None
                            width: dp(172)
                            height: dp(44)
                            md_bg_color: app.theme_tokens['success']
                            font_size: dp(13)
                            on_release: root.finalize_sale()

                        TooltipRaisedButton:
                            id: receipt_btn
                            text: "Recibo"
                            tooltip_text: "Emitir recibo | Ctrl+P"
                            size_hint: None, None
                            width: dp(160)
                            height: dp(44)
                            md_bg_color: app.theme_tokens['primary']
                            font_size: dp(13)
                            on_release: root.emit_receipt(print_now=False, preview_after=True)

                        TooltipRaisedButton:
                            id: cancel_btn
                            text: "Cancelar"
                            tooltip_text: "Cancelar venda | Ctrl+0"
                            size_hint: None, None
                            width: dp(162)
                            height: dp(44)
                            md_bg_color: app.theme_tokens['danger']
                            font_size: dp(13)
                            on_release: root.cancel_sale()

                        TooltipRaisedButton:
                            id: hold_btn
                            text: root.hold_button_text.replace(" Venda", "")
                            tooltip_text: root.hold_button_text + " | Ctrl+S"
                            size_hint: None, None
                            width: dp(176)
                            height: dp(44)
                            md_bg_color: app.theme_tokens['card_alt']
                            font_size: dp(13)
                            on_release: root.toggle_suspend_sale()

        MDCard:
            size_hint_y: None
            height: dp(58)
            radius: [dp(18)]
            elevation: 1
            md_bg_color: app.theme_tokens['surface_alt']
            padding: [dp(10), dp(8), dp(10), dp(8)]

            MDGridLayout:
                id: footer_metrics_grid
                cols: 3
                spacing: dp(8)

                MDCard:
                    radius: [dp(14)]
                    elevation: 0
                    md_bg_color: app.theme_tokens['card_alt']
                    padding: [dp(10), dp(6), dp(10), dp(6)]

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "Vendas de Hoje"
                            font_size: dp(9)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                        MDLabel:
                            id: sales_today_metric
                            text: "0"
                            bold: True
                            font_size: dp(13)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                MDCard:
                    radius: [dp(14)]
                    elevation: 0
                    md_bg_color: app.theme_tokens['card_alt']
                    padding: [dp(10), dp(6), dp(10), dp(6)]

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "Total Vendido"
                            font_size: dp(9)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                        MDLabel:
                            id: revenue_today_metric
                            text: "0.00 MT"
                            bold: True
                            font_size: dp(13)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']

                MDCard:
                    radius: [dp(14)]
                    elevation: 0
                    md_bg_color: app.theme_tokens['card_alt']
                    padding: [dp(10), dp(6), dp(10), dp(6)]

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(2)

                        MDLabel:
                            text: "Top Produto"
                            font_size: dp(9)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_muted']

                        MDLabel:
                            id: top_product_metric
                            text: "Sem dados"
                            bold: True
                            font_size: dp(13)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']
                            shorten: True
                            shorten_from: "right"

    FloatLayout:
        size_hint: 1, 1

        FloatingScannerPanel:
            id: scanner_preview_card

        MDCard:
            id: notice_overlay_card
            size_hint: None, None
            size: dp(340), dp(150)
            radius: [dp(18)]
            elevation: 4
            md_bg_color: app.theme_tokens['surface_alt'][0], app.theme_tokens['surface_alt'][1], app.theme_tokens['surface_alt'][2], 0.98
            padding: [dp(14), dp(12), dp(14), dp(12)]
            spacing: dp(8)
            orientation: "vertical"
            opacity: 0
            disabled: True

            MDBoxLayout:
                size_hint_y: None
                height: dp(24)
                spacing: dp(8)

                MDLabel:
                    id: notice_overlay_title
                    text: ""
                    bold: True
                    font_size: dp(12)
                    theme_text_color: "Custom"
                    text_color: app.theme_tokens['text_primary']

                TooltipIconButton:
                    icon: "close"
                    icon_size: sp(18)
                    theme_text_color: "Custom"
                    text_color: app.theme_tokens['text_primary']
                    md_bg_color: app.theme_tokens['card_alt']
                    hint_text: "Fechar detalhes | Esc"
                    on_release: root.close_notice_overlay()

            ScrollView:
                do_scroll_x: False
                bar_width: dp(5)

                MDLabel:
                    id: notice_overlay_body
                    text: ""
                    font_size: dp(11)
                    line_height: 1.18
                    theme_text_color: "Custom"
                    text_color: app.theme_tokens['text_secondary']
                    valign: "top"
                    text_size: self.width, None
                    size_hint_y: None
                    height: self.texture_size[1]
