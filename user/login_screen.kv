<LoginFeatureCard@MDCard>:
    radius: [dp(16)]
    elevation: 0
    padding: [dp(14), dp(12), dp(14), dp(12)]
    spacing: dp(4)
    orientation: "vertical"
    md_bg_color: app.theme_tokens['card_alt']

<LoginInfoPill@MDCard>:
    radius: [dp(16)]
    elevation: 0
    padding: [dp(12), dp(8), dp(12), dp(8)]
    md_bg_color: app.theme_tokens['card_alt']

<LoginScreen>:
    username: username_input
    password: password_input
    md_bg_color: app.theme_tokens['surface']

    FloatLayout:
        canvas.before:
            Color:
                rgba: app.theme_tokens['surface']
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba:
                    (
                    app.theme_tokens['primary'][0],
                    app.theme_tokens['primary'][1],
                    app.theme_tokens['primary'][2],
                    0.08
                    ) if root.login_variant == "admin" else (
                    app.theme_tokens['success'][0],
                    app.theme_tokens['success'][1],
                    app.theme_tokens['success'][2],
                    0.08
                    )
            Ellipse:
                size: dp(280), dp(280)
                pos: self.right - dp(200), self.top - dp(140)
            Color:
                rgba:
                    (
                    app.theme_tokens['primary'][0],
                    app.theme_tokens['primary'][1],
                    app.theme_tokens['primary'][2],
                    0.04
                    ) if root.login_variant == "admin" else (
                    app.theme_tokens['success'][0],
                    app.theme_tokens['success'][1],
                    app.theme_tokens['success'][2],
                    0.04
                    )
            Ellipse:
                size: dp(220), dp(220)
                pos: self.x - dp(60), self.y - dp(40)

        MDBoxLayout:
            id: root_layout
            orientation: "horizontal"
            spacing: dp(20)
            padding: [dp(24), dp(20), dp(24), dp(20)]

            AnchorLayout:
                id: hero_anchor
                anchor_x: "center"
                anchor_y: "top"
                size_hint_x: 0.56

                MDBoxLayout:
                    id: hero_column
                    orientation: "vertical"
                    spacing: dp(14)
                    size_hint: 1, None
                    height: self.minimum_height

                    MDCard:
                        id: admin_preview_card
                        size_hint_y: None
                        height: dp(286)
                        radius: [dp(26)]
                        elevation: 2
                        md_bg_color: app.theme_tokens['card']
                        opacity: 1 if root.login_variant == "admin" else 0
                        disabled: root.login_variant != "admin"

                        Carousel:
                            id: carousel
                            loop: True
                            direction: "right"

                            MDBoxLayout:
                                orientation: "vertical"
                                padding: [dp(18), dp(16), dp(18), dp(16)]
                                spacing: dp(12)

                                Image:
                                    id: admin_slide_one_image
                                    source: "assets/image/slide1.png"
                                    fit_mode: "contain"
                                    size_hint_y: None
                                    height: dp(170)

                                MDCard:
                                    id: admin_slide_one_summary
                                    size_hint_y: None
                                    height: dp(82)
                                    radius: [dp(18)]
                                    elevation: 0
                                    padding: [dp(16), dp(12), dp(16), dp(12)]
                                    spacing: dp(4)
                                    orientation: "vertical"
                                    md_bg_color: app.theme_tokens['card_alt']

                                    MDLabel:
                                        text: app.t("login.admin_preview.caption", app.language)
                                        font_style: "Caption"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['primary']
                                        size_hint_y: None
                                        height: dp(18)

                                    MDLabel:
                                        text: app.t("login.admin_preview.text", app.language)
                                        font_size: sp(14)
                                        bold: True
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['text_primary']
                                        text_size: self.width, None
                                        adaptive_height: True

                            MDBoxLayout:
                                orientation: "vertical"
                                padding: [dp(18), dp(16), dp(18), dp(16)]
                                spacing: dp(12)

                                Image:
                                    id: admin_slide_two_image
                                    source: "assets/image/slide6.png"
                                    fit_mode: "contain"
                                    size_hint_y: None
                                    height: dp(170)

                                MDCard:
                                    id: admin_slide_two_summary
                                    size_hint_y: None
                                    height: dp(82)
                                    radius: [dp(18)]
                                    elevation: 0
                                    padding: [dp(16), dp(12), dp(16), dp(12)]
                                    spacing: dp(4)
                                    orientation: "vertical"
                                    md_bg_color: app.theme_tokens['card_alt']

                                    MDLabel:
                                        text: app.t("login.admin_decision.caption", app.language)
                                        font_style: "Caption"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['primary']
                                        size_hint_y: None
                                        height: dp(18)

                                    MDLabel:
                                        text: app.t("login.admin_decision.text", app.language)
                                        font_size: sp(14)
                                        bold: True
                                        theme_text_color: "Custom"
                                        text_color: app.theme_tokens['text_primary']
                                        text_size: self.width, None
                                        adaptive_height: True

                    MDCard:
                        id: manager_preview_card
                        size_hint_y: None
                        height: dp(268)
                        radius: [dp(26)]
                        elevation: 2
                        md_bg_color: app.theme_tokens['card']
                        opacity: 1 if root.login_variant == "manager" else 0
                        disabled: root.login_variant != "manager"

                        MDBoxLayout:
                            orientation: "vertical"
                            padding: [dp(18), dp(16), dp(18), dp(16)]
                            spacing: dp(12)

                            Image:
                                id: manager_preview_image
                                source: "assets/image/slide2.png"
                                fit_mode: "contain"
                                size_hint_y: None
                                height: dp(160)

                            MDCard:
                                id: manager_preview_summary
                                size_hint_y: None
                                height: dp(82)
                                radius: [dp(18)]
                                elevation: 0
                                padding: [dp(16), dp(12), dp(16), dp(12)]
                                spacing: dp(4)
                                orientation: "vertical"
                                md_bg_color: app.theme_tokens['card_alt']

                                MDLabel:
                                    text: app.t("login.manager_preview.caption", app.language)
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['success']
                                    size_hint_y: None
                                    height: dp(18)

                                MDLabel:
                                    text: app.t("login.manager_preview.text", app.language)
                                    font_size: sp(14)
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_primary']
                                    text_size: self.width, None
                                    adaptive_height: True

                    MDCard:
                        id: hero_shell
                        size_hint_y: None
                        height: self.minimum_height
                        radius: [dp(24)]
                        elevation: 1
                        padding: [dp(22), dp(20), dp(22), dp(20)]
                        spacing: dp(14)
                        orientation: "vertical"
                        md_bg_color: app.theme_tokens['card']

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(34)
                            spacing: dp(10)

                            LoginInfoPill:
                                size_hint: None, None
                                size: dp(170), dp(34)
                                md_bg_color:
                                    (
                                    app.theme_tokens['primary'][0],
                                    app.theme_tokens['primary'][1],
                                    app.theme_tokens['primary'][2],
                                    0.14
                                    ) if root.login_variant == "admin" else (
                                    app.theme_tokens['success'][0],
                                    app.theme_tokens['success'][1],
                                    app.theme_tokens['success'][2],
                                    0.14
                                    )

                                MDLabel:
                                    text: root.identity_badge
                                    halign: "center"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']

                            Widget:

                            MDLabel:
                                text: root.context_label
                                halign: "right"
                                font_style: "Caption"
                                theme_text_color: "Custom"
                                text_color: app.theme_tokens['text_secondary']

                        MDLabel:
                            text: root.hero_title
                            font_size: sp(23)
                            bold: True
                            line_height: 1.0
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']
                            text_size: self.width, None
                            adaptive_height: True

                        MDLabel:
                            text: root.hero_subtitle
                            font_size: sp(13)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None
                            adaptive_height: True

                        MDGridLayout:
                            id: admin_highlights_grid
                            cols: 2
                            spacing: dp(10)
                            adaptive_height: True

                            LoginInfoPill:
                                size_hint_y: None
                                height: dp(42)
                                md_bg_color:
                                    (
                                    app.theme_tokens['primary'][0],
                                    app.theme_tokens['primary'][1],
                                    app.theme_tokens['primary'][2],
                                    0.10
                                    ) if root.login_variant == "admin" else (
                                    app.theme_tokens['success'][0],
                                    app.theme_tokens['success'][1],
                                    app.theme_tokens['success'][2],
                                    0.10
                                    )

                                MDLabel:
                                    text: root.feature_one
                                    halign: "center"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']

                            LoginInfoPill:
                                size_hint_y: None
                                height: dp(42)

                                MDLabel:
                                    text: root.quick_layout_text
                                    halign: "center"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']

            MDSeparator:
                id: divider
                orientation: "vertical"
                size_hint_x: None
                width: dp(1)
                color: app.theme_tokens['divider']

            MDScrollView:
                id: form_scroll
                do_scroll_x: False
                bar_width: 0
                size_hint_x: 0.42

                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    spacing: dp(12)
                    padding: [0, dp(6), 0, dp(6)]

                    MDBoxLayout:
                        id: form_top_actions
                        size_hint_y: None
                        height: dp(38)
                        spacing: dp(10)

                        MDFlatButton:
                            text: root.back_button_text
                            size_hint_x: None
                            width: dp(104) if root.show_back_button else 0
                            opacity: 1 if root.show_back_button else 0
                            disabled: not root.show_back_button
                            on_release: root.go_back()

                        Widget:

                        MDFillRoundFlatIconButton:
                            id: language_button
                            icon: "translate"
                            text: root.language_button_text
                            size_hint: None, None
                            size: dp(136), dp(34)
                            font_size: sp(12)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']
                            icon_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']
                            md_bg_color:
                                (
                                app.theme_tokens['primary'][0],
                                app.theme_tokens['primary'][1],
                                app.theme_tokens['primary'][2],
                                0.13
                                ) if root.login_variant == "admin" else (
                                app.theme_tokens['success'][0],
                                app.theme_tokens['success'][1],
                                app.theme_tokens['success'][2],
                                0.13
                                )
                            on_release: root.open_language_menu(self)

                        MDFlatButton:
                            text: root.theme_toggle_text
                            size_hint_x: None
                            width: dp(140) if root.show_theme_toggle else 0
                            opacity: 1 if root.show_theme_toggle else 0
                            disabled: not root.show_theme_toggle
                            on_release: root.toggle_theme()

                    MDCard:
                        id: form_column
                        size_hint_x: None
                        width: dp(430)
                        adaptive_height: True
                        pos_hint: {"center_x": 0.5}
                        radius: [dp(26)]
                        elevation: 2
                        padding: [dp(26), dp(24), dp(26), dp(24)]
                        spacing: dp(14)
                        orientation: "vertical"
                        md_bg_color: app.theme_tokens['card']

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            spacing: dp(12)

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: dp(2)

                                MDLabel:
                                    text: "MERCEARIA"
                                    font_size: sp(22)
                                    bold: True
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']
                                    size_hint_y: None
                                    height: self.texture_size[1]

                                MDLabel:
                                    text: root.profile_name
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['text_secondary']
                                    size_hint_y: None
                                    height: dp(16)

                            Widget:

                            LoginInfoPill:
                                size_hint: None, None
                                size: dp(136), dp(34)
                                md_bg_color:
                                    (
                                    app.theme_tokens['primary'][0],
                                    app.theme_tokens['primary'][1],
                                    app.theme_tokens['primary'][2],
                                    0.12
                                    ) if root.login_variant == "admin" else (
                                    app.theme_tokens['success'][0],
                                    app.theme_tokens['success'][1],
                                    app.theme_tokens['success'][2],
                                    0.12
                                    )

                                MDLabel:
                                    text: root.identity_badge
                                    halign: "center"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']

                        MDSeparator:
                            height: dp(1)

                        MDLabel:
                            text: root.login_heading
                            font_size: sp(21)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_primary']
                            text_size: self.width, None
                            adaptive_height: True

                        MDLabel:
                            text: root.login_caption
                            font_size: sp(13)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None
                            adaptive_height: True

                        MDTextField:
                            id: username_input
                            hint_text: root.username_hint
                            helper_text: root.username_error
                            helper_text_mode: "on_error"
                            mode: "rectangle"
                            size_hint_y: None
                            height: dp(54)
                            disabled: root.operation_in_progress or root.login_blocked
                            line_color_focus: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']

                        MDTextField:
                            id: password_input
                            hint_text: root.password_hint
                            helper_text: root.password_error
                            helper_text_mode: "on_error"
                            password: True
                            mode: "rectangle"
                            size_hint_y: None
                            height: dp(54)
                            disabled: root.operation_in_progress or root.login_blocked
                            line_color_focus: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']
                            on_text_validate: root.login()

                        MDRaisedButton:
                            id: login_button
                            text: root.login_button_text
                            size_hint_y: None
                            height: dp(46)
                            disabled: root.operation_in_progress or root.login_blocked
                            md_bg_color: app.theme_tokens['primary'] if root.login_variant == "admin" else app.theme_tokens['success']
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['on_primary']
                            on_release: root.login()

                        MDLabel:
                            text: root.operation_status
                            size_hint_y: None
                            height: self.texture_size[1] if root.operation_status else 0
                            opacity: 1 if root.operation_status else 0
                            halign: "center"
                            font_size: sp(12)
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None

                        MDBoxLayout:
                            id: form_links_row
                            orientation: "horizontal"
                            adaptive_height: True
                            spacing: dp(8)

                            MDFlatButton:
                                id: forgot_button
                                text: root.forgot_password_text
                                disabled: root.operation_in_progress
                                on_release: root.forgot_password()

                            MDFlatButton:
                                id: register_button
                                text: root.register_text
                                disabled: root.operation_in_progress
                                on_release: root.register()

                        MDLabel:
                            text: root.form_footer_text
                            font_style: "Caption"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: app.theme_tokens['text_secondary']
                            text_size: self.width, None
                            adaptive_height: True
